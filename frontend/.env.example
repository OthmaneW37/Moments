# Copie ce fichier en .env.production AVANT de builder pour l'app native.
# (En dev local, laisse vide : le proxy Vite gère /api tout seul.)

# URL du backend déployé (Render), SANS slash final.
VITE_API_URL=https://moments-api.onrender.com

# URL publique du frontend, pour les liens de partage /s/<token>.
# Optionnel : ne sert que si tu héberges aussi le site en ligne.
VITE_PUBLIC_URL=
